{
  "name": "poker-marketing-agency",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/ensure-sharp-libvips-link.mjs",
    "prepare": "husky",
    "dev": "concurrently -n api,vite -c cyan,green \"npm run dev:api\" \"sleep 3 && vite\"",
    "bun:dev": "npm run dev",
    "dev:local": "npm run dev:redis && concurrently -n redis,api,vite -c red,cyan,green \"docker compose logs -f redis\" \"npm run dev:api\" \"npm run dev:vite\"",
    "dev:api": "node --import tsx server/dev-api.ts",
    "dev:api:debug": "node --import tsx --trace-uncaught --trace-warnings server/dev-api.ts",
    "dev:vite": "vite",
    "dev:redis": "docker compose down redis 2>/dev/null; docker compose up -d redis",
    "dev:stop": "docker compose down",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node --import tsx server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --pool=threads",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit && tsc -p server --noEmit",
    "typecheck:server": "tsc -p server --noEmit",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "dependencies": {
